    "db:migrate": "prisma migrate deploy"
  },
  "dependencies": {
    "@archive/core": "workspace:*",
    "@aws-sdk/client-s3": "^3.839.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@prisma/client": "^6.10.1",
    "fastify": "^5.4.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
